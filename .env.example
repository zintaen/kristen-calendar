# =============================================================================
# Genie Am Lich - environment template
# =============================================================================
# Copy this file to `.env` and fill in real values:  cp .env.example .env
# Docker Compose auto-loads `.env` from the repo root for both dev and prod.
# `.env` is gitignored - never commit real secrets.
#
# Values marked [dev] are typical local defaults; [prod] are for production.
# =============================================================================

# -----------------------------------------------------------------------------
# Backend API (services/genie-api container) - SERVER-ONLY secrets
# -----------------------------------------------------------------------------

# Supabase project URL.
# [dev]  local Supabase CLI, reached from inside Docker via host.docker.internal:
#        http://host.docker.internal:54321
# [prod] your Supabase Cloud project URL, e.g. https://xxxxxxxx.supabase.co
SUPABASE_URL=http://host.docker.internal:54321

# Supabase service_role key (SERVER-ONLY - full DB access, never expose to the browser).
# [dev]  printed by `supabase start`
# [prod] Supabase dashboard -> Project Settings -> API -> service_role
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key

# Anthropic API key for the Genie proxy (SERVER-ONLY).
ANTHROPIC_API_KEY=sk-ant-replace-me

# Redis connection (rate limiting, ZNS idempotency). Inside Compose use the service name.
REDIS_URL=redis://redis:6379

# Optional: point the Genie proxy at a local OpenAI-compatible endpoint (LM Studio / Ollama)
# instead of Anthropic. Leave empty to use Anthropic.
LM_STUDIO_URL=

# ZNS (TASK-017) - fill when the Zalo OA is registered. Safe to leave as-is for dev.
ZNS_TEMPLATE_ID=
CRON_SECRET=replace-with-a-long-random-string

# Zalo Pay callback signing key (server-only). The webhook fails closed in production if unset.
ZALO_PAY_KEY2=

# App Store Server Notifications V2 (TASK-020). The webhook verifies Apple's JWS before granting.
# Place Apple Root CA - G3 in services/genie-api/certs/apple/ (see that folder's README).
APPLE_BUNDLE_ID=world.cyberskill.genieamlich
APPLE_APP_APPLE_ID=
APP_STORE_ENVIRONMENT=Sandbox
APP_STORE_ONLINE_CHECKS=false
# APP_STORE_PRODUCT_TIERS={"com.cyberskill.genie.premium.monthly":"premium","com.cyberskill.genie.family.yearly":"family"}

# -----------------------------------------------------------------------------
# Frontend (apps/web) - PUBLIC, baked into the build at BUILD TIME (not runtime).
# These ship to the browser, so use only anon/publishable values here.
# The web image reads them as build args; rebuild the image after changing them.
# -----------------------------------------------------------------------------

# Public origin the browser calls for the API. The client appends the path itself
# (config.getApiUrl("/api/genie")), so this is the ORIGIN ONLY - no trailing /api.
# [dev]  http://localhost:3000
# [prod] https://your-domain.com   (Caddy routes /api/* to the api service)
NEXT_PUBLIC_API_URL=http://localhost:3000

# Supabase URL + anon key for the browser client.
# [dev]  http://localhost:54321 + the anon key from `supabase start`
# [prod] https://xxxxxxxx.supabase.co + the anon (publishable) key
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-anon-key

# Native sign-in (Capacitor iOS/Android). Read by capacitor.config.ts and lib/auth-helpers.ts at
# native build time. Public client ids, not secrets. Leave blank for the web build; set them
# before `npx cap sync` for native Google/Apple login to work.
NEXT_PUBLIC_GOOGLE_SERVER_CLIENT_ID=
NEXT_PUBLIC_APPLE_CLIENT_ID=
NEXT_PUBLIC_APPLE_REDIRECT_URI=

# -----------------------------------------------------------------------------
# Production reverse proxy (Caddy) - only used by docker-compose.yml
# -----------------------------------------------------------------------------

# The public domain Caddy serves + gets an automatic Let's Encrypt certificate for.
DOMAIN=your-domain.com

# Email for Let's Encrypt/ACME registration and expiry notices.
ACME_EMAIL=you@example.com
