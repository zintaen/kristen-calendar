# .env.docker
# This file configures the docker-compose environment variables.

# 1. Start your local database: `npx supabase start` (run inside services/genie-api or root if initialized)
# 2. Look at the output of `supabase start`. You will see API URL and `service_role key`.

# By default, Supabase CLI runs the API at 54321 on your local machine. 
# `host.docker.internal` allows Docker containers to connect back to your local machine's Supabase instance.
SUPABASE_URL=http://host.docker.internal:54321

# Replace this with the `service_role key` printed out by `supabase start`
SUPABASE_SERVICE_ROLE_KEY=ey...

# Anthropic API Key for the Genie proxy to work
ANTHROPIC_API_KEY=sk-ant-api03...
