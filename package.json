{
  "name": "genie-amlich",
  "version": "0.0.0",
  "private": true,
  "description": "Genie Am Lich (CyberSkill) - ung dung nhac am lich Viet Nam. Monorepo, lunar math on-device theo thuat toan Ho Ngoc Duc.",
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "test:core": "pnpm --filter @cyberskill/amlich-core test",
    "gate:p0": "pnpm --filter @cyberskill/amlich-core test",
    "deploy:zalo": "pnpm --filter @cyberskill/genie-zalo build && cd zalo && npx zmp deploy"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.62.1",
    "@typescript-eslint/parser": "^8.62.1",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "prettier": "^3.9.4",
    "typescript": "^5.4.0",
    "vite": "5.4.11",
    "vitest": "^1.6.0"
  },
  "resolutions": {
    "esbuild": "0.21.5"
  }
}
