    "gate:p0": "pnpm --filter @cyberskill/amlich-core test"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.4.0",
    "vite": "5.4.11",
    "vitest": "^1.6.0"
  },
  "pnpm": {
    "overrides": {
      "esbuild": "0.21.5"
    }
  }
}
